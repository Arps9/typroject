# ====================================================================
# Backend environment variables
# Copy to backend/.env and edit values for your environment
# ====================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=compliance_audit.settings.development

# --- Database ---
# When running in docker-compose this is overridden by the compose file.
DATABASE_URL=postgres://compliance:compliance_dev_password@localhost:5432/compliance_audit

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- JWT ---
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# --- Storage ---
# 'local' or 's3'
FILE_STORAGE_BACKEND=local
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Email (dev: console backend) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@compliance-audit.local
